{
  "name": "aimate-for-pos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:dashboard": "npm run build -w @aimate/dashboard",
    "build:voice": "npm run build -w @aimate/voice-bridge",
    "dev:dashboard": "npm run dev -w @aimate/dashboard",
    "dev:voice": "npm run dev -w @aimate/voice-bridge",
    "generate:foodhub-types": "openapi-typescript rag/foodhub/raw/foodhub-openapi.json -o packages/foodhub/src/generated/foodhub.ts",
    "rag:build": "node tools/build-foodhub-rag.mjs",
    "rag:search": "node tools/search-foodhub-rag.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@google/genai": "^2.8.0",
    "ajv": "^8.17.1",
    "fastify": "^5.6.2",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.468.0",
    "mongodb": "^6.20.0",
    "next": "^16.0.10",
    "pino": "^9.14.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "stripe": "^22.2.0",
    "twilio": "^6.0.2",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "openapi-typescript": "^7.10.1",
    "tsx": "^4.20.6",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
