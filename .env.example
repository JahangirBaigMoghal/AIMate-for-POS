# Runtime
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
VOICE_BRIDGE_PORT=4100

# FoodHub Partner API
FOODHUB_BASE_URL=https://developer.foodhub.com
FOODHUB_CLIENT_ID=
FOODHUB_CLIENT_SECRET=
FOODHUB_DEFAULT_STORE_ID=
DEFAULT_STAFF_NUMBER=
DEFAULT_DELIVERY_FEE_PENCE=0

# MongoDB / Redis
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
MONGODB_DB=aimate
REDIS_URL=redis://localhost:6379

# Voice providers
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=us-central1
GEMINI_LIVE_MODEL=
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=

# Telephony
TELEPHONY_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TELNYX_API_KEY=

# Payments / Messaging
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
SMS_PROVIDER=mock

# Webhook secrets
FOODHUB_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Gemini AI
GEMINI_API_KEY=
